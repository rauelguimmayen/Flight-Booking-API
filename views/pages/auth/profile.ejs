<%- include('../../partials/header') %>
<%- include('../../partials/navbar', { page: 'profile' }) %>

<div class="container py-5" style="max-width:800px;">

  <div class="d-flex align-items-center gap-3 mb-5">
    <a href="/" class="btn btn-light rounded-circle p-2">
      <i class="bi bi-arrow-left"></i>
    </a>
    <div>
      <h1 class="fw-800 mb-0">My Profile</h1>
      <p class="text-muted mb-0 small">Manage your account details</p>
    </div>
  </div>

  <!-- Success / Error -->
  <% if (locals.success) { %>
  <div class="alert alert-success rounded-3 d-flex align-items-center gap-2 mb-4">
    <i class="bi bi-check-circle-fill"></i><span><%= success %></span>
  </div>
  <% } %>
  <% if (locals.error) { %>
  <div class="alert alert-danger rounded-3 d-flex align-items-center gap-2 mb-4">
    <i class="bi bi-exclamation-circle-fill"></i><span><%= error %></span>
  </div>
  <% } %>

  <div class="row g-4">

    <!-- Avatar + Provider -->
    <div class="col-md-4">
      <div class="bg-white rounded-4 border shadow-sm p-4 text-center">
        <% if (user.avatar) { %>
        <img src="<%= user.avatar %>" alt="<%= user.name %>"
          class="rounded-circle mb-3 border border-3 border-primary border-opacity-25"
          style="width:90px;height:90px;object-fit:cover;" />
        <% } else { %>
        <div class="user-avatar-lg mx-auto mb-3 rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-800 fs-3"
          style="width:90px;height:90px;">
          <%= user.name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2) %>
        </div>
        <% } %>

        <h5 class="fw-800 mb-1"><%= user.name %></h5>
        <p class="text-muted small mb-3"><%= user.email %></p>

        <% if (user.provider === 'google') { %>
        <span class="badge bg-light text-dark border d-inline-flex align-items-center gap-1 px-3 py-2">
          <svg width="14" height="14" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
          Google Account
        </span>
        <% } else { %>
        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2">
          <i class="bi bi-envelope me-1"></i>Email Account
        </span>
        <% } %>

        <div class="mt-3 text-muted small">
          Member since <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %>
        </div>
      </div>
    </div>

    <!-- Edit Form -->
    <div class="col-md-8">

      <!-- Update Name -->
      <div class="bg-white rounded-4 border shadow-sm p-4 mb-4">
        <h6 class="fw-700 mb-3"><i class="bi bi-person me-2 text-primary"></i>Personal Info</h6>
        <form action="/auth/profile/update" method="POST">
          <div class="mb-3">
            <label class="form-label fw-600 small">Full Name</label>
            <input type="text" name="name" class="form-control rounded-3"
              value="<%= user.name %>" required />
          </div>
          <div class="mb-3">
            <label class="form-label fw-600 small">Email Address</label>
            <input type="email" class="form-control rounded-3 bg-light"
              value="<%= user.email %>" disabled />
            <div class="form-text">Email cannot be changed.</div>
          </div>
          <button type="submit" class="btn btn-primary rounded-3 fw-700 px-4">
            <i class="bi bi-check me-1"></i>Save Changes
          </button>
        </form>
      </div>

      <!-- Change Password (only for local users) -->
      <% if (user.provider === 'local') { %>
      <div class="bg-white rounded-4 border shadow-sm p-4 mb-4">
        <h6 class="fw-700 mb-3"><i class="bi bi-lock me-2 text-primary"></i>Change Password</h6>
        <form action="/auth/profile/password" method="POST">
          <div class="mb-3">
            <label class="form-label fw-600 small">Current Password</label>
            <input type="password" name="currentPassword" class="form-control rounded-3"
              placeholder="••••••••" required />
          </div>
          <div class="mb-3">
            <label class="form-label fw-600 small">New Password</label>
            <input type="password" name="newPassword" class="form-control rounded-3"
              placeholder="Min. 6 characters" required minlength="6" />
          </div>
          <div class="mb-4">
            <label class="form-label fw-600 small">Confirm New Password</label>
            <input type="password" name="confirmPassword" class="form-control rounded-3"
              placeholder="Repeat new password" required />
          </div>
          <button type="submit" class="btn btn-outline-primary rounded-3 fw-700 px-4">
            <i class="bi bi-shield-lock me-1"></i>Update Password
          </button>
        </form>
      </div>
      <% } %>

      <!-- Danger Zone -->
      <div class="bg-white rounded-4 border border-danger border-opacity-25 shadow-sm p-4">
        <h6 class="fw-700 mb-1 text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Danger Zone</h6>
        <p class="text-muted small mb-3">Once you delete your account, all data will be permanently removed.</p>
        <button type="button" class="btn btn-outline-danger rounded-3 fw-700 btn-sm"
          data-bs-toggle="modal" data-bs-target="#deleteModal">
          <i class="bi bi-trash me-1"></i>Delete Account
        </button>
      </div>

    </div>
  </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-800 text-danger">Delete Account</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body pt-2">
        <p class="text-muted">This will permanently delete your account and all your bookings. This action <strong>cannot be undone</strong>.</p>
      </div>
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-light rounded-3 fw-600" data-bs-dismiss="modal">Cancel</button>
        <form action="/auth/profile/delete" method="POST" class="d-inline">
          <button type="submit" class="btn btn-danger rounded-3 fw-700">
            <i class="bi bi-trash me-1"></i>Yes, Delete
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
