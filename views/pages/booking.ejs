<%- include('../partials/header') %>
<%- include('../partials/navbar', { page: 'booking' }) %>

<div class="container py-4">
  <a href="javascript:history.back()" class="text-muted text-decoration-none d-inline-flex align-items-center gap-2 mb-4">
    <i class="bi bi-arrow-left"></i> Back
  </a>

  <div class="row g-4">
    <!-- Main Form -->
    <div class="col-lg-8">
      <!-- Step Indicator -->
      <div class="d-flex align-items-center mb-4" id="stepIndicator">
        <% const steps = [
          {id:'passengers', label:'Passengers', icon:'bi-person'},
          {id:'seats', label:'Seats', icon:'bi-grid'},
          {id:'extras', label:'Extras', icon:'bi-luggage'},
          {id:'payment', label:'Payment', icon:'bi-credit-card'}
        ]; %>
        <% steps.forEach((s, i) => { %>
        <div class="d-flex align-items-center flex-grow-1">
          <div class="step-indicator-item flex-shrink-0" data-step="<%= i %>">
            <div class="step-circle <%= i===0 ? 'active' : '' %>" id="stepCircle-<%= i %>">
              <i class="bi <%= s.icon %>" id="stepIcon-<%= i %>"></i>
            </div>
            <div class="step-label text-muted small mt-1 text-center d-none d-sm-block" id="stepLabel-<%= i %>"><%= s.label %></div>
          </div>
          <% if (i < steps.length - 1) { %>
          <div class="step-line flex-grow-1 mx-2" id="stepLine-<%= i %>"></div>
          <% } %>
        </div>
        <% }) %>
      </div>

      <!-- Step Content -->
      <form id="bookingForm" method="POST" action="/booking/confirm">
        <input type="hidden" name="flight" value="<%= JSON.stringify(flight) %>" />
        <input type="hidden" name="tripType" value="<%= tripType %>" />
        <input type="hidden" name="cabinClass" value="<%= cabinClass %>" />
        <input type="hidden" name="passengers" value="<%= JSON.stringify(passengers) %>" />
        <input type="hidden" name="selected_seats" id="selectedSeatsInput" value="[]" />

        <!-- Step 0: Passengers -->
        <div class="step-content" id="step-0">
          <div class="bg-white rounded-4 border p-4 shadow-sm">
            <h5 class="fw-700 mb-4"><i class="bi bi-person-fill me-2 text-primary"></i>Passenger Details</h5>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-600 small">Full Name *</label>
                <input type="text" class="form-control rounded-3" name="passenger_name" id="passengerName"
                  placeholder="As on passport" required />
              </div>
              <div class="col-md-6">
                <label class="form-label fw-600 small">Email Address *</label>
                <input type="email" class="form-control rounded-3" name="passenger_email" id="passengerEmail"
                  placeholder="your@email.com" required />
              </div>
              <div class="col-md-6">
                <label class="form-label fw-600 small">Phone Number</label>
                <input type="tel" class="form-control rounded-3" name="passenger_phone"
                  placeholder="+1 234 567 8900" />
              </div>
              <div class="col-md-6">
                <label class="form-label fw-600 small">Date of Birth</label>
                <input type="date" class="form-control rounded-3" name="date_of_birth" />
              </div>
              <div class="col-md-6">
                <label class="form-label fw-600 small">Passport Number</label>
                <input type="text" class="form-control rounded-3" name="passport_number" placeholder="AB1234567" />
              </div>
              <div class="col-md-6">
                <label class="form-label fw-600 small">Nationality</label>
                <select class="form-select rounded-3" name="nationality">
                  <option value="">Select country</option>
                  <option>United States</option>
                  <option>United Kingdom</option>
                  <option>Philippines</option>
                  <option>Canada</option>
                  <option>Australia</option>
                  <option>Germany</option>
                  <option>France</option>
                  <option>Japan</option>
                  <option>Other</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 1: Seat Selection -->
        <div class="step-content d-none" id="step-1">
          <div class="bg-white rounded-4 border p-4 shadow-sm">
            <h5 class="fw-700 mb-2"><i class="bi bi-grid-fill me-2 text-primary"></i>Select Your Seat</h5>
            <p class="text-muted small mb-4">Click a seat to select it. Green = available, Gray = occupied, Blue = selected.</p>

            <!-- Cabin legend -->
            <div class="d-flex gap-3 mb-4 flex-wrap">
              <div class="d-flex align-items-center gap-2 small">
                <div class="seat-legend bg-success"></div>Available
              </div>
              <div class="d-flex align-items-center gap-2 small">
                <div class="seat-legend bg-secondary"></div>Occupied
              </div>
              <div class="d-flex align-items-center gap-2 small">
                <div class="seat-legend bg-primary"></div>Selected
              </div>
              <div class="d-flex align-items-center gap-2 small">
                <div class="seat-legend bg-warning"></div>Extra Legroom
              </div>
            </div>

            <!-- Seat Map -->
            <div class="seat-map-wrapper text-center">
              <div class="seat-map d-inline-block">
                <div class="text-center mb-3">
                  <div class="airplane-nose mx-auto mb-2">✈</div>
                  <div class="d-flex justify-content-center gap-2 mb-2 small text-muted fw-600">
                    <span style="width:36px">A</span>
                    <span style="width:36px">B</span>
                    <span style="width:36px">C</span>
                    <span style="width:24px"></span>
                    <span style="width:36px">D</span>
                    <span style="width:36px">E</span>
                    <span style="width:36px">F</span>
                  </div>
                </div>
                <div id="seatGrid"></div>
              </div>
            </div>
            <p class="text-center text-muted small mt-3" id="seatSelectionInfo">No seat selected (optional)</p>
          </div>
        </div>

        <!-- Step 2: Baggage / Extras -->
        <div class="step-content d-none" id="step-2">
          <div class="bg-white rounded-4 border p-4 shadow-sm">
            <h5 class="fw-700 mb-4"><i class="bi bi-luggage-fill me-2 text-primary"></i>Baggage & Extras</h5>

            <div class="row g-3">
              <!-- Carry-on -->
              <div class="col-12">
                <div class="extra-card border rounded-3 p-3 d-flex align-items-center justify-content-between">
                  <div class="d-flex gap-3 align-items-center">
                    <div class="extra-icon bg-primary bg-opacity-10 text-primary rounded-3 p-2">
                      <i class="bi bi-bag fs-5"></i>
                    </div>
                    <div>
                      <div class="fw-600 small">Carry-on Bag</div>
                      <div class="text-muted" style="font-size:11px">1 bag, up to 7kg – Included</div>
                    </div>
                  </div>
                  <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" name="baggage_carry_on" value="true"
                      id="carryOn" checked disabled />
                    <span class="badge bg-success ms-2">Free</span>
                  </div>
                </div>
              </div>

              <!-- Checked Bags -->
              <div class="col-12">
                <div class="extra-card border rounded-3 p-3">
                  <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex gap-3 align-items-center">
                      <div class="extra-icon bg-warning bg-opacity-10 text-warning rounded-3 p-2">
                        <i class="bi bi-luggage fs-5"></i>
                      </div>
                      <div>
                        <div class="fw-600 small">Checked Bags</div>
                        <div class="text-muted" style="font-size:11px">$45 per bag, up to 23kg</div>
                      </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                      <button type="button" class="btn btn-outline-secondary btn-sm rounded-circle px-2"
                        id="bagMinus"><i class="bi bi-dash"></i></button>
                      <span class="fw-700 px-2" id="bagCount">0</span>
                      <button type="button" class="btn btn-outline-primary btn-sm rounded-circle px-2"
                        id="bagPlus"><i class="bi bi-plus"></i></button>
                      <input type="hidden" name="baggage_checked_bags" id="bagCountInput" value="0" />
                    </div>
                  </div>
                </div>
              </div>

              <!-- Extra Legroom -->
              <div class="col-12">
                <div class="extra-card border rounded-3 p-3 d-flex align-items-center justify-content-between">
                  <div class="d-flex gap-3 align-items-center">
                    <div class="extra-icon bg-success bg-opacity-10 text-success rounded-3 p-2">
                      <i class="bi bi-arrows-expand-vertical fs-5"></i>
                    </div>
                    <div>
                      <div class="fw-600 small">Extra Legroom</div>
                      <div class="text-muted" style="font-size:11px">Additional 6" legroom – $35</div>
                    </div>
                  </div>
                  <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" name="baggage_extra_legroom" value="true"
                      id="extraLegroom" onchange="updateSummary()" />
                  </div>
                </div>
              </div>

              <!-- Meal Preference -->
              <div class="col-12">
                <div class="extra-card border rounded-3 p-3">
                  <div class="d-flex gap-3 align-items-start">
                    <div class="extra-icon bg-danger bg-opacity-10 text-danger rounded-3 p-2">
                      <i class="bi bi-cup-hot fs-5"></i>
                    </div>
                    <div class="flex-grow-1">
                      <div class="fw-600 small mb-2">Meal Preference <span class="badge bg-secondary ms-1">Free</span></div>
                      <select class="form-select form-select-sm rounded-3" name="meal_preference">
                        <option value="standard">Standard Meal</option>
                        <option value="vegetarian">Vegetarian</option>
                        <option value="vegan">Vegan</option>
                        <option value="halal">Halal</option>
                        <option value="kosher">Kosher</option>
                        <option value="none">No meal</option>
                      </select>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3: Payment -->
        <div class="step-content d-none" id="step-3">
          <div class="bg-white rounded-4 border p-4 shadow-sm">
            <h5 class="fw-700 mb-4"><i class="bi bi-credit-card-fill me-2 text-primary"></i>Payment</h5>

            <!-- Payment Method -->
            <div class="d-flex gap-3 mb-4 flex-wrap">
              <label class="payment-method-btn flex-grow-1">
                <input type="radio" name="payment_method" value="card" checked class="d-none" />
                <div class="border rounded-3 p-3 text-center cursor-pointer payment-opt active">
                  <i class="bi bi-credit-card fs-4 text-primary mb-1 d-block"></i>
                  <small class="fw-600">Credit Card</small>
                </div>
              </label>
              <label class="payment-method-btn flex-grow-1">
                <input type="radio" name="payment_method" value="paypal" class="d-none" />
                <div class="border rounded-3 p-3 text-center cursor-pointer payment-opt">
                  <i class="bi bi-paypal fs-4 text-primary mb-1 d-block"></i>
                  <small class="fw-600">PayPal</small>
                </div>
              </label>
              <label class="payment-method-btn flex-grow-1">
                <input type="radio" name="payment_method" value="gcash" class="d-none" />
                <div class="border rounded-3 p-3 text-center cursor-pointer payment-opt">
                  <i class="bi bi-phone fs-4 text-success mb-1 d-block"></i>
                  <small class="fw-600">GCash</small>
                </div>
              </label>
            </div>

            <!-- Card Details -->
            <div id="cardDetails">
              <div class="row g-3">
                <div class="col-12">
                  <label class="form-label fw-600 small">Card Number</label>
                  <input type="text" class="form-control rounded-3" placeholder="1234 5678 9012 3456"
                    maxlength="19" id="cardNumber" />
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-600 small">Cardholder Name</label>
                  <input type="text" class="form-control rounded-3" placeholder="John Doe" />
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-600 small">Expiry</label>
                  <input type="text" class="form-control rounded-3" placeholder="MM/YY" maxlength="5" />
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-600 small">CVV</label>
                  <input type="text" class="form-control rounded-3" placeholder="123" maxlength="4" />
                </div>
              </div>
            </div>

            <div class="alert alert-info rounded-3 mt-3 small">
              <i class="bi bi-shield-lock me-2"></i>
              Your payment information is encrypted and secure. We never store your card details.
            </div>
          </div>
        </div>

        <!-- Nav Buttons -->
        <div class="d-flex justify-content-between mt-4">
          <button type="button" class="btn btn-outline-secondary rounded-3 px-4" id="prevBtn" style="display:none!important">
            <i class="bi bi-arrow-left me-2"></i>Back
          </button>
          <div class="ms-auto">
            <button type="button" class="btn btn-primary rounded-3 px-5 fw-700" id="nextBtn">
              Continue <i class="bi bi-arrow-right ms-2"></i>
            </button>
            <button type="submit" class="btn btn-success rounded-3 px-5 fw-700 d-none" id="confirmBtn">
              <i class="bi bi-check-circle me-2"></i>Confirm & Pay
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- Booking Summary Sidebar -->
    <div class="col-lg-4">
      <div class="bg-white rounded-4 border shadow-sm p-4 sticky-top" style="top:80px;">
        <h6 class="fw-700 mb-3">Booking Summary</h6>

        <!-- Flight Info -->
        <div class="flight-summary-card bg-light rounded-3 p-3 mb-3">
          <div class="d-flex align-items-center gap-2 mb-3">
            <div class="airline-badge bg-primary text-white rounded-3 px-2 py-1 fw-700 small">
              <%= flight.airlineCode || 'XX' %>
            </div>
            <div>
              <div class="fw-700 small"><%= flight.airline || 'Airline' %></div>
              <div class="text-muted" style="font-size:11px"><%= flight.flightNumber || '' %></div>
            </div>
          </div>
          <div class="d-flex align-items-center gap-2">
            <div class="text-center">
              <div class="fw-800 fs-5"><%= flight.departureTime || '--:--' %></div>
              <div class="text-muted small"><%= flight.originCode || '---' %></div>
            </div>
            <div class="flex-grow-1 text-center">
              <div class="text-muted" style="font-size:11px"><%= flight.duration || '' %></div>
              <div class="flight-line position-relative">
                <div class="border-top border-secondary w-100"></div>
                <i class="bi bi-airplane-fill position-absolute text-primary" style="top:-8px;left:50%;transform:translateX(-50%)"></i>
              </div>
              <div class="text-muted" style="font-size:11px">
                <%= flight.stops === 0 ? 'Non-stop' : (flight.stops || 0) + ' stop(s)' %>
              </div>
            </div>
            <div class="text-center">
              <div class="fw-800 fs-5"><%= flight.arrivalTime || '--:--' %></div>
              <div class="text-muted small"><%= flight.destinationCode || '---' %></div>
            </div>
          </div>
        </div>

        <!-- Price Breakdown -->
        <div class="mb-3">
          <div class="d-flex justify-content-between small mb-2">
            <span class="text-muted">Base fare × <%= (parseInt(passengers.adults)||1) + (parseInt(passengers.children)||0) + (parseInt(passengers.infants)||0) %></span>
            <span class="fw-600" id="summaryBase">
              $<%= ((flight.price||0) * ((parseInt(passengers.adults)||1) + (parseInt(passengers.children)||0) + (parseInt(passengers.infants)||0))).toFixed(0) %>
            </span>
          </div>
          <div class="d-flex justify-content-between small mb-2">
            <span class="text-muted">Baggage extras</span>
            <span class="fw-600" id="summaryBaggage">$0</span>
          </div>
          <div class="d-flex justify-content-between small mb-2">
            <span class="text-muted">Taxes & fees (12%)</span>
            <span class="fw-600" id="summaryTax">
              $<%= Math.round((flight.price||0) * ((parseInt(passengers.adults)||1) + (parseInt(passengers.children)||0) + (parseInt(passengers.infants)||0)) * 0.12) %>
            </span>
          </div>
          <hr />
          <div class="d-flex justify-content-between fw-800 text-primary">
            <span>Total</span>
            <span id="summaryTotal">
              $<%= Math.round((flight.price||0) * ((parseInt(passengers.adults)||1) + (parseInt(passengers.children)||0) + (parseInt(passengers.infants)||0)) * 1.12) %>
            </span>
          </div>
        </div>

        <div class="alert alert-success rounded-3 small py-2 px-3">
          <i class="bi bi-check-circle me-1"></i>Free cancellation within 24 hours
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.BOOKING_DATA = {
    flightPrice: <%= flight.price || 0 %>,
    passengersCount: <%= (parseInt(passengers.adults)||1) + (parseInt(passengers.children)||0) + (parseInt(passengers.infants)||0) %>
  };
</script>
<script src="/js/booking.js"></script>

<%- include('../partials/footer') %>
