<%- include('../partials/header') %>
<%- include('../partials/navbar', { page: 'deals' }) %>

<div class="container py-5">
  <!-- Header -->
  <div class="text-center mb-5">
    <div class="badge bg-warning bg-opacity-15 text-warning border border-warning border-opacity-25 px-3 py-2 rounded-pill mb-3 fw-700">
      <i class="bi bi-lightning-charge-fill me-1"></i>Limited Time Offers
    </div>
    <h1 class="fw-800 display-5 mb-3">Flight Deals Worth Flying For</h1>
    <p class="text-muted lead mx-auto" style="max-width:500px;">
      Hand-picked deals updated daily. Book fast — these prices don't last long!
    </p>
  </div>

  <!-- Deals Grid -->
  <div class="row g-4">
    <% deals.forEach((deal, i) => { %>
    <div class="col-sm-6 col-lg-4 col-xl-3">
      <div class="deal-card bg-white rounded-4 border shadow-sm overflow-hidden hover-lift h-100">
        <div class="position-relative overflow-hidden" style="height:176px;">
          <img src="<%= deal.img %>" alt="<%= deal.city %>"
            class="w-100 h-100 deal-img" style="object-fit:cover;transition:transform 0.5s;" />
          <div class="position-absolute inset-0 bg-gradient-to-top"></div>
          <span class="badge position-absolute top-0 start-0 m-3 fw-700 tag-badge"><%= deal.tag %></span>
          <span class="badge bg-success position-absolute top-0 end-0 m-3 fw-700">-<%= deal.savings %>%</span>
        </div>

        <div class="card-body p-3">
          <div class="d-flex justify-content-between align-items-start mb-1">
            <div>
              <h6 class="fw-800 mb-0"><%= deal.city %></h6>
              <small class="text-muted"><i class="bi bi-geo-alt me-1"></i><%= deal.country %></small>
            </div>
            <div class="text-end">
              <div class="text-muted text-decoration-line-through small">$<%= deal.originalPrice %></div>
              <div class="fw-800 text-primary">$<%= deal.price %></div>
            </div>
          </div>

          <div class="text-danger small fw-600 mb-2">
            <i class="bi bi-clock me-1"></i>Expires in <%= deal.expires %>
          </div>
          <div class="text-muted small mb-3">
            <i class="bi bi-airplane me-1"></i><%= deal.from %> → <%= deal.code %> · Round trip
          </div>

          <a href="/search?originCode=<%= deal.from %>&destinationCode=<%= deal.code %>&originDisplay=<%= deal.from %>&destinationDisplay=<%= deal.city %>&tripType=round-trip&cabinClass=economy&adults=1&children=0&infants=0"
            class="btn btn-primary rounded-3 w-100 btn-sm fw-700">
            Book Now <i class="bi bi-arrow-right ms-1"></i>
          </a>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>
