<%- include('../partials/header') %>
<%- include('../partials/navbar', { page: '' }) %>

<div class="error-page text-center py-5">
  <div class="container">
    <div class="mb-4" style="font-size:5rem">⚠️</div>
    <h1 class="fw-800 display-5 text-danger">Server Error</h1>
    <p class="text-muted lead mb-3">Something went wrong on our end. We're working to fix it.</p>
    <% if (locals.error && process.env.NODE_ENV === 'development') { %>
    <div class="alert alert-danger rounded-3 text-start d-inline-block mb-4" style="max-width:600px">
      <code><%= error %></code>
    </div>
    <% } %>
    <div class="d-flex gap-3 justify-content-center flex-wrap">
      <a href="/" class="btn btn-primary rounded-3 px-5 fw-700">
        <i class="bi bi-house me-2"></i>Go Home
      </a>
      <button onclick="history.back()" class="btn btn-outline-secondary rounded-3 px-5 fw-700">
        <i class="bi bi-arrow-left me-2"></i>Go Back
      </button>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
