<%- include('../partials/header') %>
<%- include('../partials/navbar', { page: 'home' }) %>

<!-- Hero Section -->
<section class="hero-section text-white text-center position-relative overflow-hidden">
  <div class="hero-overlay"></div>
  <div class="hero-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
  </div>
  <div class="container position-relative z-2 py-5">
    <div class="py-4">
      <div class="badge bg-white bg-opacity-25 text-white border border-white border-opacity-30 px-3 py-2 rounded-pill mb-4 fs-7 fw-600">
        <i class="bi bi-airplane-fill me-1"></i>500+ Airlines · Best Price Guaranteed
      </div>
      <h1 class="display-3 fw-800 mb-3 lh-sm">
        Fly Anywhere,<br>
        <span class="text-warning">Pay Less</span>
      </h1>
      <p class="lead text-white-50 mb-5 mx-auto" style="max-width:480px">
        Search and compare flights from hundreds of airlines. Find your perfect deal in seconds.
      </p>
    </div>

    <!-- Search Form -->
    <div class="mt-2 pb-5">
      <%- include('../partials/search_form') %>
    </div>
  </div>
</section>

<!-- Features Section -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="row g-4">
      <div class="col-md-4">
        <div class="feature-card bg-white rounded-4 p-4 border h-100 d-flex gap-3 align-items-start shadow-sm hover-lift">
          <div class="feature-icon bg-warning bg-opacity-10 text-warning rounded-3 p-3 flex-shrink-0">
            <i class="bi bi-lightning-charge-fill fs-4"></i>
          </div>
          <div>
            <h6 class="fw-700 mb-1">Lightning Search</h6>
            <p class="text-muted small mb-0">Compare 500+ airlines in seconds</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card bg-white rounded-4 p-4 border h-100 d-flex gap-3 align-items-start shadow-sm hover-lift">
          <div class="feature-icon bg-success bg-opacity-10 text-success rounded-3 p-3 flex-shrink-0">
            <i class="bi bi-shield-check-fill fs-4"></i>
          </div>
          <div>
            <h6 class="fw-700 mb-1">Secure Booking</h6>
            <p class="text-muted small mb-0">Your payment is always protected</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card bg-white rounded-4 p-4 border h-100 d-flex gap-3 align-items-start shadow-sm hover-lift">
          <div class="feature-icon bg-purple bg-opacity-10 text-purple rounded-3 p-3 flex-shrink-0">
            <i class="bi bi-headset fs-4"></i>
          </div>
          <div>
            <h6 class="fw-700 mb-1">24/7 Support</h6>
            <p class="text-muted small mb-0">Real humans ready to help anytime</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Popular Destinations -->
<section class="py-5">
  <div class="container">
    <div class="d-flex align-items-end justify-content-between mb-4">
      <div>
        <h2 class="fw-800 mb-1">Popular Destinations</h2>
        <p class="text-muted mb-0">Trending routes with the best prices</p>
      </div>
      <a href="/deals" class="btn btn-link text-primary fw-700 text-decoration-none">
        View all <i class="bi bi-arrow-right"></i>
      </a>
    </div>

    <div class="row g-4">
      <% destinations.forEach((dest, i) => { %>
      <div class="col-sm-6 col-lg-4">
        <div class="dest-card position-relative rounded-4 overflow-hidden shadow-sm hover-lift cursor-pointer"
          style="height:220px;">
          <img src="<%= dest.img %>" alt="<%= dest.city %>" class="w-100 h-100 dest-img" />
          <div class="dest-overlay position-absolute inset-0"></div>
          <% if (dest.tag) { %>
          <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-3 fw-700">
            <%= dest.tag %>
          </span>
          <% } %>
          <div class="position-absolute bottom-0 start-0 end-0 p-3 text-white">
            <div class="d-flex justify-content-between align-items-end">
              <div>
                <h5 class="fw-800 mb-0"><%= dest.city %></h5>
                <small class="text-white-50"><i class="bi bi-geo-alt me-1"></i><%= dest.country %></small>
              </div>
              <div class="text-end">
                <div class="text-white-50 small">from</div>
                <div class="fw-800 fs-5">$<%= dest.price %></div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
